# Airtable — create a personal access token scoped to ONLY the Bulldogs base
# https://airtable.com/create/tokens
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Shared password the 3 coaches type to log in
PORTAL_PASSWORD=change-me

# Long random string used to sign session cookies (e.g. `openssl rand -hex 32`)
SESSION_SECRET=change-me-to-a-long-random-string
